# Supabase Postgres connection string (transaction pooler DSN).
DATABASE_URL=postgresql://postgres.yrqraepkwrlxajyonwxj:PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# Upstash native Redis (TCP/TLS) endpoint used as the Celery broker.
# NOTE: this is the rediss:// URL from the Upstash console, NOT the REST URL/token.
REDIS_URL=rediss://default:TOKEN@your-db.upstash.io:6379

# How often to poll PHIVOLCS, in seconds (default 300 = 5 minutes).
POLL_INTERVAL_SECONDS=300

# Path to the local historical catalog CSV file.
HISTORICAL_CSV_PATH=phivolcs_earthquake_2018_2026.csv

